# Development environment variables — loaded by Expo automatically when running in dev mode.
# Override in your shell or .env.development.local (git-ignored) for machine-specific values.
#
# EXPO_PUBLIC_ prefix is required — Expo only exposes EXPO_PUBLIC_ prefixed vars to the
# client bundle at build time, matching web's VITE_ prefix convention.
EXPO_PUBLIC_SOCKET_URL=https://real-time-chat-production-757a.up.railway.app