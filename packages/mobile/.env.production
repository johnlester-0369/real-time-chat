# Production environment variables — loaded by Expo during production builds.
# In EAS Build, set EXPO_PUBLIC_SOCKET_URL as a build environment variable —
# that value takes precedence over this file, same as Vercel/Railway do for web.
#
# EXPO_PUBLIC_ prefix is required — Expo strips unprefixed vars from the client bundle.
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000