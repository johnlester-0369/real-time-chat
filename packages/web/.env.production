# Production environment variables — loaded by Vite automatically during `vite build`.
# In CI/CD or hosting platforms (Vercel, Railway, Fly.io, etc.), set VITE_SOCKET_URL
# to your deployed backend URL — that value takes precedence over this file.
#
# VITE_ prefix is required — Vite strips unprefixed vars from the browser bundle at build time.
VITE_SOCKET_URL=http://localhost:3000