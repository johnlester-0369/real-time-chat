# Environment variable template — commit this file.
# Copy to .env for local development, or set these vars in your deployment platform.
#
# Railway: Settings → Variables → Add Variable
# Render:  Environment → Environment Variables → Add Variable

# ──────────────────────────────────────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────────────────────────────────────

# Port the HTTP server listens on.
# Railway and Render inject PORT automatically — this default is for local dev only.
PORT=3000

# ──────────────────────────────────────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────────────────────────────────────

# Comma-separated list of origins the server accepts WebSocket/HTTP requests from.
# Add every frontend URL that needs to connect to this server.
#
# Examples:
#   Local dev:   http://localhost:5173
#   Render:      https://real-time-chat-johnlester-0369.onrender.com
#   Vercel:      https://your-app.vercel.app
#   Multiple:    https://your-frontend.onrender.com,https://your-app.vercel.app
#
# Leaving this unset falls back to localhost-only (safe for local dev, breaks production).
CORS_ORIGIN=http://localhost:5173,http://localhost:4173